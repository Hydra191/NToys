{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ntoys",
  "version": "0.0.0",
  "identifier": "NToys",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        },
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "binaries/v2ray.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/Hydra191/NToys/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMjM0NDg3MzEyQzA3ODgKUldTSUJ5d3hoMFFqWDlqVk12c0liU3ZNelcrc0pwTnJEL0RTb0wxUExZTUNnaVNrK2hPT0tTcmEK"
    }
  }
}
